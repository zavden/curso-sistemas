FROM alpine:latest

# Dynamic UID/GID via build arguments
ARG USER_UID=1000
ARG USER_GID=1000

# Create group and user with the specified UID/GID
RUN addgroup -g $USER_GID devuser && \
    adduser -u $USER_UID -G devuser -D devuser

# Switch to the non-root user
USER devuser
WORKDIR /home/devuser

CMD ["sh", "-c", "echo 'generated by devuser' > /app/output.txt && echo 'File created successfully'"]
