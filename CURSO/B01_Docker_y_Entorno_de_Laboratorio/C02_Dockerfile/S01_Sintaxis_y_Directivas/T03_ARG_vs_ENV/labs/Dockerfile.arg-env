FROM alpine:latest

# ARG receives value during build
ARG APP_VERSION=1.0.0

# ENV persists it into the image
ENV APP_VERSION=${APP_VERSION}

RUN echo "Build version: $APP_VERSION" > /build-info.txt

CMD ["sh", "-c", "echo '=== Build info ===' && cat /build-info.txt && echo '=== Runtime ===' && echo \"APP_VERSION=$APP_VERSION\""]
